<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ryan.bartill.ui.ReceiptController"
      spacing="10">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label text="Receipt" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <Label fx:id="metaLabel" text="Sale #"/>

    <Separator/>

    <ListView fx:id="linesListView" prefHeight="300"/>

    <Separator/>

    <GridPane hgap="10" vgap="8">
        <Label text="Payment Method:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="paymentMethodLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Total (ex VAT):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="totalExLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="VAT:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="vatLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Total (inc VAT):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="totalIncLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Amount received:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="cashLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Change:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <Label fx:id="changeLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Back to POS" onAction="#onBackClicked"/>
    </HBox>
</VBox>